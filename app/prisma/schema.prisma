generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Rol {
  OPERARIO
  SUPERVISOR
  GERENCIA
}

enum TipoMaquina {
  LASER
  PUNZONADORA_CNC
  FRESADORA
  EXPANSORA
  PLEGADORA
  PLEGADO_MANUAL
  LAVADO
  PINTADO
  HORNO
  EMBALAJE
  DESPACHO
}

enum EstadoMaquina {
  OPERATIVA
  MANTENIMIENTO
  FUERA_DE_SERVICIO
}

enum Unidad {
  PIEZAS
  METROS
  M2
}

enum EstadoOrden {
  PENDIENTE
  EN_PRODUCCION
  EN_ESPERA
  COMPLETADA
  CANCELADA
}

enum EstadoEjecucion {
  PENDIENTE
  ACTIVA
  EN_ESPERA
  COMPLETADA
}

enum EstadoProyecto {
  ACTIVO
  COMPLETADO
  CANCELADO
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  rol       Rol
  maquinaId String?
  createdAt DateTime @default(now())

  maquina     Maquina?           @relation(fields: [maquinaId], references: [id])
  ejecuciones EjecucionEtapa[]
  registros   RegistroProgreso[]
  tramos      TramoTrabajo[]
}

model Proyecto {
  id           String         @id @default(cuid())
  nombre       String
  cliente      String
  fechaEntrega DateTime
  estado       EstadoProyecto @default(ACTIVO)
  createdAt    DateTime       @default(now())

  ordenes OrdenProduccion[]
}

model Maquina {
  id           String        @id @default(cuid())
  nombre       String
  tipo         TipoMaquina
  estadoActual EstadoMaquina @default(OPERATIVA)

  operarios   Usuario[]
  etapasRuta  EtapaRuta[]
  ejecuciones EjecucionEtapa[]
  tramos      TramoTrabajo[]
}

model Ruta {
  id          String  @id @default(cuid())
  sistema     String
  producto    String
  descripcion String?

  etapas  EtapaRuta[]
  ordenes OrdenProduccion[]

  @@unique([sistema, producto])
}

model EtapaRuta {
  id               String @id @default(cuid())
  rutaId           String
  maquinaId        String
  ordenSecuencia   Int
  nombreEtapa      String
  umbralActivacion Float  @default(100)

  ruta        Ruta             @relation(fields: [rutaId], references: [id])
  maquina     Maquina          @relation(fields: [maquinaId], references: [id])
  ejecuciones EjecucionEtapa[]
}

model OrdenProduccion {
  id               String      @id @default(cuid())
  proyectoId       String?
  rutaId           String
  sistema          String
  producto         String
  cantidad         Float
  unidad           Unidad
  porcentajeGlobal Float       @default(0)
  estado           EstadoOrden @default(PENDIENTE)
  prioridad        Int         @default(0)
  createdAt        DateTime    @default(now())

  proyecto    Proyecto?        @relation(fields: [proyectoId], references: [id])
  ruta        Ruta             @relation(fields: [rutaId], references: [id])
  ejecuciones EjecucionEtapa[]
}

model EjecucionEtapa {
  id               String          @id @default(cuid())
  ordenId          String
  etapaRutaId      String
  maquinaId        String
  operarioId       String?
  porcentajeActual Float           @default(0)
  estado           EstadoEjecucion @default(PENDIENTE)
  fueOverride      Boolean         @default(false)
  fechaInicio      DateTime?
  fechaFin         DateTime?
  ultimoProgresoEn DateTime?
  createdAt        DateTime        @default(now())

  orden      OrdenProduccion    @relation(fields: [ordenId], references: [id])
  etapaRuta  EtapaRuta          @relation(fields: [etapaRutaId], references: [id])
  maquina    Maquina            @relation(fields: [maquinaId], references: [id])
  operario   Usuario?           @relation(fields: [operarioId], references: [id])
  registros  RegistroProgreso[]
  tramos     TramoTrabajo[]
}

model Configuracion {
  id                      String   @id @default("singleton")
  horasSinActividadAlerta Int      @default(4)
  creadoEn                DateTime @default(now())
  actualizadoEn           DateTime @updatedAt
}

model AlertaLog {
  id          String    @id @default(cuid())
  ejecucionId String
  ordenId     String
  ordenNombre String
  etapaNombre String
  tipo        String
  severidad   String
  disparadaEn DateTime  @default(now())
  resueltaEn  DateTime?
}

model RegistroProgreso {
  id                   String   @id @default(cuid())
  ejecucionEtapaId     String
  usuarioId            String
  porcentajeRegistrado Float
  cantidadRegistrada   Float
  timestamp            DateTime @default(now())
  notas                String?
  fueOverride          Boolean  @default(false)
  motivoOverride       String?

  ejecucionEtapa EjecucionEtapa @relation(fields: [ejecucionEtapaId], references: [id])
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
}

enum TipoTramo {
  PREPARACION
  PRODUCCION
}

enum MotivoPausa {
  MATERIAL
  OTRA_ORDEN
  AVERIA
  OTRO
}

model CapacidadTeorica {
  id                   String      @id @default(cuid())
  producto             String
  tipoMaquina          TipoMaquina
  piezasPorHora        Float
  minutosSetupEstimado Float?
  vigenteDesde         DateTime    @default(now())

  @@unique([producto, tipoMaquina, vigenteDesde])
}

model TramoTrabajo {
  id                String       @id @default(cuid())
  ejecucionEtapaId  String
  operarioId        String
  maquinaId         String
  tipo              TipoTramo
  inicio            DateTime     @default(now())
  fin               DateTime?
  cantidadProducida Float?
  motivoPausa       MotivoPausa?
  dudoso            Boolean      @default(false)
  notas             String?
  createdAt         DateTime     @default(now())

  ejecucionEtapa EjecucionEtapa @relation(fields: [ejecucionEtapaId], references: [id])
  operario       Usuario        @relation(fields: [operarioId], references: [id])
  maquina        Maquina        @relation(fields: [maquinaId], references: [id])
}

enum CondicionIva {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTO
  EXENTO
}

enum EstadoCotizacion {
  BORRADOR
  ENVIADA
  VISTA
  ACEPTADA
  RECHAZADA
}

enum AlcanceCotizacion {
  PROVISION
  PROVISION_MONTAJE
}

enum ModoPagoMontaje {
  INCLUIDO_PAQUETE
  CERTIFICACIONES
}

enum TipoRetencion {
  IVA
  GANANCIAS
  IIBB
  SUSS
}

enum CentroTrabajo {
  LASER
  PLEGADORA
  PUNZONADORA
  PINTURA
  EMBALADO
}

model Cliente {
  id             String       @id @default(cuid())
  razonSocial    String
  cuit           String       @unique
  condicionIva   CondicionIva
  domicilioFiscal String?
  jurisdiccionIibb String?
  esAgenteRetencion Boolean    @default(false)
  createdAt      DateTime     @default(now())

  contactos   Contacto[]
  cotizaciones Cotizacion[]
}

model Contacto {
  id        String  @id @default(cuid())
  clienteId String
  nombre    String
  cargo     String?
  email     String
  telefono  String?

  cliente Cliente @relation(fields: [clienteId], references: [id])
}

model Cotizacion {
  id            String            @id @default(cuid())
  numero        String            @unique
  clienteId     String
  proyectoId    String?
  version       Int               @default(1)
  estado        EstadoCotizacion  @default(BORRADOR)
  alcance       AlcanceCotizacion @default(PROVISION)
  margenPct     Float             @default(0)
  totalProducto Float             @default(0)
  totalMontaje  Float             @default(0)
  tcUsado       Float
  ubicacionObra String?
  createdAt     DateTime          @default(now())

  cliente          Cliente                  @relation(fields: [clienteId], references: [id])
  vanos            CotizacionVano[]
  condiciones      CondicionesComerciales?
  listaMateriales  ListaMateriales?
}

model CotizacionVano {
  id           String @id @default(cuid())
  cotizacionId String
  sistema      String
  material     String
  terminacion  String
  ancho        Float
  alto         Float
  costoFab     Float  @default(0)
  costoMaterial Float @default(0)
  precio       Float  @default(0)
  cara         String?
  geometria    Json?
  compras      Json?

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id])
}

model CondicionesComerciales {
  id             String          @id @default(cuid())
  cotizacionId   String          @unique
  formaPagoProducto String
  modoPagoMontaje ModoPagoMontaje @default(INCLUIDO_PAQUETE)
  variosPct      Float           @default(10)

  cotizacion    Cotizacion      @relation(fields: [cotizacionId], references: [id])
  retenciones   Retencion[]
  certificaciones Certificacion[]
}

model Retencion {
  id          String        @id @default(cuid())
  condicionId String
  tipo        TipoRetencion
  porcentaje  Float

  condicion CondicionesComerciales @relation(fields: [condicionId], references: [id])
}

model Certificacion {
  id          String  @id @default(cuid())
  condicionId String
  descripcion String
  porcentaje  Float
  monto       Float?

  condicion CondicionesComerciales @relation(fields: [condicionId], references: [id])
}

model ParametroCosteo {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     Float
  unidad    String?
  descripcion String?
  actualizadoEn DateTime @updatedAt
}

model CapacidadCentro {
  id        String        @id @default(cuid())
  pieza     String
  centro    CentroTrabajo
  unidadesPorDia Float?
  actualizadoEn  DateTime  @updatedAt

  @@unique([pieza, centro])
}

model FactorKp {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     Float
  actualizadoEn DateTime @updatedAt
}

model SistemaCotizador {
  id        String  @id @default(cuid())
  nombre    String  @unique
  activo    Boolean @default(true)
}

model MaterialCotizador {
  id        String  @id @default(cuid())
  codigo    String  @unique
  nombre    String
  precioU   Float?
  unidad    String  @default("kg")
}

model MedioElevacion {
  id          String  @id @default(cuid())
  nombre      String  @unique
  alturaMaxM  Float
  costoDia    Float?
}

model CatalogoRenglonMontaje {
  id        String  @id @default(cuid())
  nombre    String  @unique
  categoria String
  unidad    String
  activo    Boolean @default(true)
}

model MaterialFamilia {
  id           String   @id @default(cuid())
  nombre       String   @unique
  densidad     Float
  precioTon    Float
  precioM2     Float    @default(0)
  actualizadoEn DateTime @updatedAt
}

model MaterialVariante {
  id           String   @id @default(cuid())
  material     String   @unique
  familia      String
  espesorMm    Float
  actualizadoEn DateTime @updatedAt
}

model DisenoKp {
  id           String   @id @default(cuid())
  diseno       String   @unique
  kp           Float
  actualizadoEn DateTime @updatedAt
}

model ListaMateriales {
  id           String            @id
  cotizacionId String            @unique
  cotizacion   Cotizacion        @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  estado       String            @default("EN_REVISION")
  createdAt    DateTime          @default(now())
  liberadaAt   DateTime?
  lineas       LineaMateriales[]
}

model LineaMateriales {
  id           String          @id
  listaId      String
  lista        ListaMateriales @relation(fields: [listaId], references: [id], onDelete: Cascade)
  area         String
  cara         String?
  insumo       String
  unidad       String
  cantidad     Float
  cantidadCalc Float?
  origen       String
  nota         String?
  orden        Int             @default(0)

  @@index([listaId])
}
